{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://postplus.local/schemas/amazon-dataset.schema.json",
  "title": "Amazon Dataset",
  "type": "object",
  "required": ["schemaVersion", "normalizedAt", "itemCount", "items"],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "normalizedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "properties": {
        "collectionPath": {
          "type": ["string", "null"]
        },
        "fetchedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "inputPath": {
          "type": ["string", "null"]
        },
        "sourceDatasetPath": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "itemCount": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entityType", "identity", "raw"],
        "properties": {
          "entityType": {
            "type": "string",
            "enum": ["product", "review"]
          },
          "source": {
            "type": "object",
            "additionalProperties": true
          },
          "identity": {
            "type": "object",
            "properties": {
              "asin": {
                "type": ["string", "null"]
              },
              "parentAsin": {
                "type": ["string", "null"]
              },
              "title": {
                "type": ["string", "null"]
              },
              "productUrl": {
                "type": ["string", "null"]
              },
              "brand": {
                "type": ["string", "null"]
              }
            },
            "additionalProperties": true
          },
          "pricing": {
            "type": "object",
            "additionalProperties": true
          },
          "proof": {
            "type": "object",
            "additionalProperties": true
          },
          "seller": {
            "type": "object",
            "additionalProperties": true
          },
          "merchandising": {
            "type": "object",
            "additionalProperties": true
          },
          "review": {
            "type": "object",
            "additionalProperties": true
          },
          "specs": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "media": {
            "type": "object",
            "additionalProperties": true
          },
          "raw": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
